{
  "rewrites": [
    { "source": "/games", "destination": "/index.html" },
    { "source": "/matches", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/player/(.*)", "destination": "/index.html" },
    { "source": "/chats", "destination": "/index.html" },
    { "source": "/reviews", "destination": "/index.html" },
    { "source": "/shop", "destination": "/index.html" },
    { "source": "/gemini", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
